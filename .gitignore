# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
.utmp/
*.log

/project/.utmp/
/project/[Ll]ibrary/
/project/[Tt]emp/
/project/[Oo]bj/
/project/[Bb]uild/
/project/[Bb]uilds/
/project/[Ll]ogs/
/project/[Uu]ser[Ss]ettings/
/project/*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
/project/*.blend1
/project/*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/project/[Mm]emoryCaptures/

# Recordings can get excessive in size
/project/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/project/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
project/ExportedObj/
project/.consulo/
project/*.csproj
project/*.unityproj
project/*.sln
project/*.suo
project/*.tmp
project/*.user
project/*.userprefs
project/*.pidb
project/*.booproj
project/*.svd
project/*.pdb
project/*.mdb
project/*.opendb
project/*.VC.db

# Unity3D generated meta files
project/*.pidb.meta
project/*.pdb.meta
project/*.mdb.meta

# Unity3D generated file on crash reports
project/sysinfo.txt

# Mono auto generated files
project/mono_crash.*

# Builds
project/*.apk
project/*.aab
project/*.unitypackage
project/*.unitypackage.meta
project/*.app

# Crashlytics generated file
project/crashlytics-build.properties

# TestRunner generated files
project/InitTestScene*.unity*

# Addressables default ignores, before user customizations
/project/ServerData
/project/[Aa]ssets/StreamingAssets/aa*
/project/[Aa]ssets/AddressableAssetsData/link.xml*
/project/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/project/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/project/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/project/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
